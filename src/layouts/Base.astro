---
import { site } from '../config/site';
import tokens from '../styles/tokens.css?raw';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { title, description, path = '/', jsonld = [] } = Astro.props;
const canonical = site.baseUrl + path;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  {site.languages.map((l) => (
    <link rel="alternate" hreflang={l.code} href={site.baseUrl + l.path + path} />
  ))}
  <link rel="alternate" hreflang="x-default" href={site.baseUrl + path} />
  <style is:inline set:html={tokens}></style>
  {jsonld.map((obj) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(obj)}></script>
  ))}
</head>
<body>
  <Header />
  <slot />
  <Footer />
  <script is:inline src={`https://widgets.bokun.io/assets/javascripts/apps/build/BokunWidgetsLoader.js?bookingChannelUUID=${site.product.bokunChannel}`} async></script>
</body>
</html>
